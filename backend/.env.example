# Application
APP_NAME="Goethe Exam Platform"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=goethe_platform
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# AI Providers
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-1.5-pro
DEFAULT_AI_PROVIDER=openai

# Cloudflare R2 Storage
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY=your-access-key
CLOUDFLARE_R2_SECRET_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET=goethe-platform

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAILS_FROM_EMAIL=noreply@goetheplatform.com

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,https://goethe-platform.vercel.app

# Admin
FIRST_SUPERUSER_EMAIL=admin@goetheplatform.com
FIRST_SUPERUSER_PASSWORD=change-me-in-production

# Sentry (optional)
SENTRY_DSN=
